{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Loki logs datasource",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "logs",
      "name": "Logs",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "uid": "cantolico-security",
  "title": "Cantólico — Security",
  "description": "Security monitoring dashboard: unauthorized attempts, critical actions, and access patterns",
  "tags": ["cantolico", "security"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Security Overview",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Unauthorized Attempts/min",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(rate({app=\"cantolico\"} | json | tags=~\".*unauthorized.*\" [1m]))",
          "legendFormat": "Unauthorized/min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Security Events/min",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "dark-red", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(rate({app=\"cantolico\",level=\"security\"}[1m]))",
          "legendFormat": "Security Events/min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Critical Actions",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 8 },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "count_over_time({app=\"cantolico\"} | json | tags=~\".*critical-action.*\" [$__range])",
          "legendFormat": "Critical Actions",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Large File Uploads",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 8 },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 20 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "count_over_time({app=\"cantolico\"} | json | tags=~\".*large-file.*\" [$__range])",
          "legendFormat": "Large File Uploads",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "Security Event Logs",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Security Event Log",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 10 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{app=\"cantolico\",level=\"security\"} | json",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Critical Actions Log",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 10 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{app=\"cantolico\"} | json | tags=~\".*critical-action.*\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "Access Patterns",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 1 }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Unauthorized Access by IP",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 10 },
      "options": {
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "enablePagination": false
        },
        "showHeader": true,
        "sortBy": [
          { "displayName": "Value", "desc": true }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "custom": {
            "align": "auto",
            "displayMode": "color-background",
            "inspect": false
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ip_address" },
            "properties": [
              { "id": "displayName", "value": "IP Address" },
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Attempt Count" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (ip_address) (count_over_time({app=\"cantolico\"} | json | tags=~\".*unauthorized.*\" [$__range]))",
          "legendFormat": "{{ip_address}}",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "rows"
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              { "displayName": "Value", "desc": true }
            ]
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Admin Attempts by User",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 10 },
      "options": {
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "enablePagination": false
        },
        "showHeader": true,
        "sortBy": [
          { "displayName": "Value", "desc": true }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          },
          "custom": {
            "align": "auto",
            "displayMode": "color-background",
            "inspect": false
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "user_email" },
            "properties": [
              { "id": "displayName", "value": "User Email" },
              { "id": "custom.width", "value": 260 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Event Count" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (user_email) (count_over_time({app=\"cantolico\",level=\"security\"} | json [$__range]))",
          "legendFormat": "{{user_email}}",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "rows"
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              { "displayName": "Value", "desc": true }
            ]
          }
        }
      ]
    }
  ]
}
